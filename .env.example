# Copy this file to .env, then replace every blank value with an independently generated secret.
# Examples: openssl rand -base64 32 (passwords), openssl rand -base64 48 (JWT_SECRET).
DB_ROOT_PASSWORD=
DB_PASSWORD=
REDIS_PASSWORD=
JWT_SECRET=
LANCHAT_BOOTSTRAP_ADMIN_PASSWORD=

LANCHAT_PORT=8080
LANCHAT_BOOTSTRAP_ADMIN_NICKNAME=系统管理员
LANCHAT_NODE_ID=
LANCHAT_NODE_NAME=LanChat Private Node
LANCHAT_ORGANIZATION_NAME=Private Organization
LANCHAT_MODE=LOCAL_INDEPENDENT
LANCHAT_ADVERTISED_HOST=
LANCHAT_ADVERTISED_PORT=8080
LANCHAT_NODE_SECURE=false
LANCHAT_DISCOVERY_ENABLED=false
LANCHAT_DISCOVERY_INTERFACE_ADDRESS=
WEBSOCKET_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
AUTH_COOKIE_SECURE=false
LANCHAT_LOG_MAX_FILE_SIZE=20MB
LANCHAT_LOG_MAX_HISTORY=30
LANCHAT_LOG_TOTAL_SIZE_CAP=1GB
LANCHAT_RUNTIME_LOG_MAX_READ_BYTES=4194304
