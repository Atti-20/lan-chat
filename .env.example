# Copy this file to .env, then replace every blank password/key value with an independently generated secret.
# LANCHAT_ADVERTISED_HOST and LANCHAT_DISCOVERY_INTERFACE_ADDRESS may remain blank for automatic selection.
# Examples: openssl rand -base64 32 (passwords), openssl rand -base64 48 (JWT_SECRET).
DB_ROOT_PASSWORD=
DB_PASSWORD=
REDIS_PASSWORD=
JWT_SECRET=
LANCHAT_BOOTSTRAP_ADMIN_PASSWORD=
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

LANCHAT_PORT=8080
LANCHAT_BOOTSTRAP_ADMIN_NICKNAME=系统管理员
LANCHAT_NODE_ID=lanchat-private
LANCHAT_NODE_NAME=LanChat Private Node
LANCHAT_ORGANIZATION_NAME=Private Organization
LANCHAT_MODE=LAN_FIRST
LANCHAT_ADVERTISED_HOST=
LANCHAT_ADVERTISED_PORT=8080
LANCHAT_NODE_SECURE=false
LANCHAT_DISCOVERY_ENABLED=false
LANCHAT_DISCOVERY_INTERFACE_ADDRESS=
LANCHAT_CLUSTER_ENABLED=true
LANCHAT_CLUSTER_ID=lanchat-private
LANCHAT_CLUSTER_CHANNEL=lanchat:lanchat-private:realtime:v1
LANCHAT_PRESENCE_TTL_SECONDS=75
LANCHAT_PRESENCE_HEARTBEAT_SECONDS=20
FILE_STORAGE_TYPE=MINIO
FILE_UPLOAD_CHUNK_SIZE=8388608
FILE_UPLOAD_TTL_HOURS=24
FILE_UPLOAD_MAX_CONCURRENCY=3
FILE_UPLOAD_CLEANUP_FIXED_DELAY_MS=600000
FILE_UPLOAD_CLEANUP_INITIAL_DELAY_MS=60000
FILE_OBJECT_CLEANUP_FIXED_DELAY_MS=60000
FILE_OBJECT_CLEANUP_INITIAL_DELAY_MS=60000
MINIO_BUCKET=lanchat-files
MINIO_CONSOLE_PORT=9001
WEBSOCKET_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
AUTH_COOKIE_SECURE=false
LANCHAT_LOG_MAX_FILE_SIZE=20MB
LANCHAT_LOG_MAX_HISTORY=30
LANCHAT_LOG_TOTAL_SIZE_CAP=1GB
LANCHAT_RUNTIME_LOG_MAX_READ_BYTES=4194304
