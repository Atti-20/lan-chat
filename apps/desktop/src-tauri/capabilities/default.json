{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Minimal permissions for the LANChat main window.",
  "windows": ["main"],
  "platforms": ["macOS"],
  "permissions": [
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "core:resources:default",
    "dialog:allow-message"
  ]
}
