{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Permissions used by the LANChat desktop shell.",
  "windows": ["main"],
  "platforms": ["macOS", "windows", "linux"],
  "permissions": [
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "core:resources:default",
    "dialog:allow-message",
    "notification:default",
    "autostart:default",
    "updater:default",
    "process:allow-restart",
    "deep-link:default"
  ]
}
