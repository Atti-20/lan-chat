{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MeshX",
  "version": "3.0.0",
  "identifier": "com.atti20.lanchat",
  "build": {
    "beforeDevCommand": "npm --prefix ../../frontend run dev:desktop",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm --prefix ../../frontend run build:desktop",
    "frontendDist": "../../../frontend/dist-desktop"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MeshX",
        "width": 1280,
        "height": 820,
        "minWidth": 360,
        "minHeight": 480,
        "center": true,
        "resizable": true,
        "visible": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "connect-src": "ipc: http://ipc.localhost http: https: ws: wss:",
        "img-src": "'self' asset: http://asset.localhost http: https: data: blob:",
        "style-src": "'self' 'unsafe-inline'",
        "font-src": "'self' data:",
        "media-src": "'self' http: https: blob:"
      }
    }
  },
  "bundle": {
    "active": true,
    "category": "SocialNetworking",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "LAN-first private collaboration client",
    "longDescription": "MeshX provides private messaging and file collaboration for organization-controlled local networks."
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["MeshX"]
      }
    },
    "updater": {
      "endpoints": [],
      "pubkey": ""
    }
  }
}
