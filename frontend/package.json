{
  "name": "lanchat-web",
  "private": true,
  "version": "3.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:desktop": "vite --mode desktop --host 127.0.0.1 --port 1420 --strictPort",
    "test": "node --test tests/*.test.mjs",
    "test:sha256": "node --test tests/sha256.test.mjs",
    "test:sequence": "node --test tests/sequence.test.mjs",
    "typecheck": "vue-tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "build:desktop": "npm run typecheck && vite build --mode desktop",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "vue": "3.5.39"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "6.0.7",
    "typescript": "5.9.3",
    "vite": "8.1.3",
    "vue-tsc": "3.2.5"
  }
}
