{
  "name": "lanchat-web",
  "private": true,
  "version": "2.3.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "test": "node --test tests/*.test.mjs",
    "test:sha256": "node --test tests/sha256.test.mjs",
    "test:sequence": "node --test tests/sequence.test.mjs",
    "typecheck": "vue-tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "vue": "3.5.39"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "6.0.7",
    "typescript": "5.9.3",
    "vite": "8.1.3",
    "vue-tsc": "3.2.5"
  }
}
